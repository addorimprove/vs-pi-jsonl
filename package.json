{
  "name": "pi-session-preview",
  "displayName": "Pi Session Preview",
  "description": "Optional, read-only local preview for Pi session JSONL files.",
  "version": "0.0.1",
  "publisher": "rajan",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/rajan-personal/pi-session-preview"
  },
  "homepage": "https://github.com/rajan-personal/pi-session-preview#readme",
  "bugs": {
    "url": "https://github.com/rajan-personal/pi-session-preview/issues"
  },
  "keywords": [
    "pi",
    "jsonl",
    "session",
    "preview",
    "read-only"
  ],
  "engines": {
    "vscode": "^1.127.0"
  },
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "main": "./dist/extension/extension.js",
  "activationEvents": [
    "onCustomEditor:piSessionPreview.preview",
    "onCommand:piSessionPreview.openPreview",
    "onCommand:piSessionPreview.openSource"
  ],
  "contributes": {
    "commands": [
      {
        "command": "piSessionPreview.openPreview",
        "title": "Open Pi Session Preview",
        "icon": "$(preview)"
      },
      {
        "command": "piSessionPreview.openSource",
        "title": "Open JSONL Source",
        "icon": "$(code)"
      }
    ],
    "customEditors": [
      {
        "viewType": "piSessionPreview.preview",
        "displayName": "Pi Session Preview",
        "selector": [
          {
            "filenamePattern": "*.jsonl"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "piSessionPreview.openPreview",
          "when": "resourceExtname == .jsonl && activeEditor == workbench.editors.textEditor",
          "group": "navigation@10"
        },
        {
          "command": "piSessionPreview.openSource",
          "when": "activeCustomEditorId == piSessionPreview.preview",
          "group": "navigation@10"
        }
      ]
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true }); require('node:fs').rmSync('media/main.js', { force: true })\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:extension": "tsc -p tsconfig.build.json",
    "build:webview": "esbuild src/webview/main.ts --bundle --format=iife --platform=browser --target=es2022 --outfile=media/main.js",
    "build": "npm run clean && npm run typecheck && npm run build:extension && npm run build:webview",
    "test:unit": "node --test dist/test/unit/**/*.test.js",
    "test": "npm run build && npm run test:unit",
    "integration-test": "npm run build && node --test dist/test/integration/**/*.test.js",
    "integration-test:vscode": "npm run build && node dist/test/vscode/run-test.js",
    "test:package": "npm run package:vsix && node --test dist/test/packaging/**/*.test.js",
    "benchmark:large": "npm run build && node --expose-gc dist/test/performance/large-file-benchmark.js",
    "package:vsix": "npm run build && vsce package --no-dependencies --out pi-session-preview.vsix",
    "verify": "npm run lint && npm run typecheck && npm test && npm run integration-test && npm run integration-test:vscode && npm run test:package && npm audit --omit=dev --audit-level=high"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.125.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "axe-core": "^4.12.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "jsdom": "^26.1.0",
    "mocha": "^11.7.6",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5"
  }
}
